{
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "apps/blog/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/blog(.*)",
      "dest": "apps/blog"
    },
    {
      "src": "/(.*)",
      "dest": "apps/web"
    }
  ]
}