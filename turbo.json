{
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ],
      "env": [
        "INTERNAL_CONFIG",
        "BLOG_URL",
        "VERCEL_ENV",
        "VERCEL_URL",
        "VERCEL_BRANCH_URL"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "start": {
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}